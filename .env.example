# Environment Variables for AI Resume Analyzer

# VITE_PUTER_APP_ID is used for identifying the application instance
VITE_PUTER_APP_ID=your_app_id_here

# Add other configuration variables needed for deployment
# VITE_API_URL for backend API endpoint
VITE_API_URL=https://api.yourservice.com

# VITE_ENV indicates the environment (development, staging, production)
VITE_ENV=development

# VITE_PORT specifies the port for the application
VITE_PORT=3000
